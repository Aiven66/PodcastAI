{
  "name": "podcastai-desktop",
  "version": "1.0.4",
  "description": "PodcastAI Desktop Client",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node copy-assets.js",
    "dev": "tsc -p tsconfig.json && node copy-assets.js && electron .",
    "pack:mac": "tsc -p tsconfig.json && node copy-assets.js && electron-builder --mac",
    "pack:mac:arm64": "tsc -p tsconfig.json && node copy-assets.js && electron-builder --mac --arm64",
    "pack:win": "tsc -p tsconfig.json && node copy-assets.js && electron-builder --win --x64",
    "pack:all": "tsc -p tsconfig.json && node copy-assets.js && electron-builder --mac && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.podcastai.desktop",
    "productName": "PodcastAI",
    "directories": {
      "output": "../public/downloads",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "voice-runtime",
        "to": "voice-runtime",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/.DS_Store",
          "!**/._*"
        ]
      }
    ],
    "afterPack": "./afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "notarize": false,
      "forceCodeSigning": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5"
  }
}
