{
  "name": "podcastai-desktop",
  "version": "1.0.0",
  "description": "PodcastAI Desktop Client",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && electron .",
    "pack:mac": "electron-builder --mac --arm64 --x64",
    "pack:win": "electron-builder --win --x64",
    "pack:all": "electron-builder --mac --arm64 --x64 && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.podcastai.desktop",
    "productName": "PodcastAI",
    "directories": {
      "output": "../public/downloads",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5"
  }
}
